# Generated communication content is not committed by default.
# (Examples live under examples/, which IS committed.)
output/*
!output/.gitkeep

# Local Claude Code permission settings (machine-specific)
.claude/settings.local.json

# Private source materials (papers, manuscripts, restricted data) —
# never synced to GitHub
papers/

# OS / editor noise
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
